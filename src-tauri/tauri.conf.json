{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentManager",
  "version": "0.1.0",
  "identifier": "com.xiaocao.agentmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentManager",
        "width": 420,
        "height": 900,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "center": false,
        "x": 0,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
